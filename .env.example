# Lucky Spin Casino — backend config (copy to server/.env, or set in your shell).
# This is a SEPARATE company from Mock Bank; it only talks to the bank over HTTP.

PORT=4100
FRONTEND_URL=http://localhost:5180
JWT_SECRET=lucky-spin-dev-secret-change-me

# The Mock Bank we integrate with.
BANK_API_URL=http://localhost:3000/api
BANK_WEB_URL=http://localhost:5173
# Partner API key issued to us by the bank (seeded by the bank's `pnpm db:seed`).
BANK_PARTNER_KEY=sk_test_luckyspin_dev

# How we appear on the cardholder's bank statement.
MERCHANT_NAME=Lucky Spin Casino

# Frontend (web/.env, optional) — origin of the bank's hosted Connect page:
# VITE_BANK_WEB_URL=http://localhost:5173
